{
  "host_name": "localhost",
  "server": {
    "upload_auth_key": "your_upload_auth_key_here",
    "server_url": "http://localhost:5001"
  },
  "authentication": {
    "enabled": true,
    "session_duration_days": 7,
    "password_min_length": 8
  },
  "email": {
    "smtp_server": "smtp.gmail.com",
    "smtp_port": 587,
    "smtp_username": "your_email@gmail.com",
    "smtp_password": "your_app_password",
    "from_email": "Your Name <your_email@gmail.com>",
    "to_email": "recipient@example.com",
    "use_tls": true
  },
  "tools": {
    "openclaw": {
      "enabled": true,
      "token_env": "OPENCLAW_TOKEN",
      "gateway_url": "http://127.0.0.1:18789",
      "hostname": "localhost"
    },
    "claude": {
      "enabled": true,
      "hostname": "localhost"
    },
    "qwen": {
      "enabled": true,
      "hostname": "localhost"
    }
  },
  "cron": {
    "enabled": true,
    "run_time": "00:30"
  },
  "feishu": {
    "app_id": "cli_xxxxxxxxxxxxx",
    "app_secret": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
  }
}
