[Unit]
Description=AI Token Analyzer - OpenClaw Data Collection
After=network.target

[Service]
Type=simple
User=openclaw
Group=openclaw
WorkingDirectory=/opt/ai-token-analyzer
Environment="PYTHONUNBUFFERED=1"
ExecStart=/usr/bin/python3 /opt/ai-token-analyzer/scripts/fetch_openclaw_messages.py --days 1

[Install]
WantedBy=multi-user.target
